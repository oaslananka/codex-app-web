# Safe local defaults for codex-app-web
UI_HOST=127.0.0.1
PORT=1989
PORT_FALLBACK=1990
CODEX_LISTEN=ws://127.0.0.1:40000
CODEX_BACKEND_URL=ws://127.0.0.1:40000
ALLOWED_HOSTS=127.0.0.1:1989,localhost:1989
ALLOWED_ORIGINS=http://127.0.0.1:1989,http://localhost:1989
MAX_WS_PAYLOAD_BYTES=1048576
MAX_BACKEND_WS_PAYLOAD_BYTES=16777216
MAX_WS_BUFFERED_BYTES=1048576
MAX_UPLOAD_BYTES=10485760
SHOW_LAN_URLS=0
DEV_LAN_ACCESS=0
TRUST_PROXY_HEADERS=0
ALLOW_NEXT_DEV_FALLBACK=0

# Optional: set a stable local token for non-browser clients.
# Browser sessions receive an HttpOnly SameSite=Strict local cookie automatically.
# CODEX_UI_TOKEN=

# Development LAN helper: pnpm dev:lan sets UI_HOST=0.0.0.0 and
# DEV_LAN_ACCESS=1 so private IPv4 LAN Host/Origin values are accepted in
# development only. SHOW_LAN_URLS only controls logging.
#
# Production/private deployment LAN mode is intentionally opt-in. When UI_HOST
# is 0.0.0.0 in production, set explicit ALLOWED_HOSTS, ALLOWED_ORIGINS, and
# CODEX_UI_TOKEN values for that LAN endpoint.

# Set TRUST_PROXY_HEADERS=1 only when the app is behind a trusted TLS reverse
# proxy that overwrites X-Forwarded-Proto. Secure cookies use that signal only
# in trusted proxy mode.
