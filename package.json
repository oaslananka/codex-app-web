{
  "name": "codex-app-web",
  "version": "1.1.7",
  "description": "Independent, open-source web control center compatible with Codex app-server workflows",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "main": "server.cjs",
  "files": [
    ".env.example",
    ".github",
    ".gitleaks.toml",
    ".prettierignore",
    ".prettierrc",
    ".release-please-manifest.json",
    "app",
    "assets",
    "azure-pipelines.yml",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "codex-official-docs",
    "CONTRIBUTING.md",
    "docs",
    "eslint.config.mjs",
    "knip.jsonc",
    "LICENSE",
    "LICENSES",
    "license-policy.json",
    "next.config.ts",
    "package.json",
    "playwright.config.ts",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "postcss.config.mjs",
    "README.md",
    "release-please-config.json",
    "REUSE.toml",
    "scripts",
    "SECURITY.md",
    "server.cjs",
    "src",
    "start-all.cjs",
    "stryker.config.json",
    "SUPPORT.md",
    "TECH_DEBT.md",
    "tests",
    "tsconfig.json",
    "typedoc.json",
    "vitest.config.ts"
  ],
  "scripts": {
    "typecheck": "next typegen && tsc --noEmit",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "protocol:manifest:generate": "node scripts/generate-codex-manifest.mjs",
    "protocol:manifest:check": "node scripts/generate-codex-manifest.mjs --check",
    "protocol:drift:check": "node scripts/check-codex-protocol-drift.mjs",
    "protocol:sync:upstream": "node scripts/sync-codex-upstream.mjs",
    "repo:hygiene:check": "node scripts/check-repository-hygiene.mjs",
    "quality:dead-code": "knip --reporter compact",
    "quality:size": "node scripts/check-size-budgets.mjs",
    "docs:build": "typedoc --options typedoc.json",
    "docs:check": "pnpm docs:build && node scripts/check-generated-docs.mjs docs/api",
    "license:reuse": "node scripts/check-reuse-compliance.mjs",
    "license:reuse:report": "node scripts/check-reuse-compliance.mjs --spdx-report dist/license-report/reuse.spdx",
    "license:dependencies": "node scripts/check-dependency-licenses.mjs",
    "license:scan": "pnpm license:reuse && pnpm license:dependencies",
    "security:bootstrap": "node scripts/security-tools.mjs bootstrap",
    "security:actions": "node scripts/security-tools.mjs actions",
    "security:secrets": "node scripts/security-tools.mjs secrets",
    "security:trivy": "node scripts/security-tools.mjs trivy",
    "security:scan": "node scripts/security-tools.mjs scan",
    "release:state": "node scripts/check-release-state.mjs",
    "release:dry-run": "node scripts/check-release-state.mjs",
    "ci": "pnpm format:check && pnpm lint && pnpm repo:hygiene:check && pnpm quality:dead-code && pnpm protocol:manifest:check && pnpm protocol:drift:check && pnpm docs:check && pnpm typecheck && pnpm test:coverage && pnpm build && pnpm test:e2e:ci && pnpm test:mutation && pnpm quality:size && pnpm security:scan && pnpm release:dry-run",
    "sync:vendor": "node scripts/sync-public-vendor-assets.mjs",
    "postinstall": "node scripts/sync-public-vendor-assets.mjs",
    "start": "node scripts/sync-public-vendor-assets.mjs && cross-env NODE_ENV=production PORT=1989 PORT_FALLBACK=1990 node server.cjs",
    "start:reuse": "cross-env NODE_ENV=production PORT=1989 PORT_FALLBACK=1990 CODEX_REUSE_EXISTING=1 UI_COMMAND=\"node server.cjs\" node start-all.cjs",
    "start:ui": "node scripts/sync-public-vendor-assets.mjs && node server.cjs",
    "start:codex": "codex app-server --listen ws://127.0.0.1:40000",
    "start:mock-codex": "node scripts/mock-codex-app-server.mjs",
    "start:prod": "pnpm build && pnpm start",
    "dev": "node scripts/sync-public-vendor-assets.mjs && cross-env NODE_ENV=development ALLOW_NEXT_DEV_FALLBACK=1 PORT=1989 PORT_FALLBACK=1990 UI_COMMAND=\"node server.cjs\" node start-all.cjs",
    "dev:reuse": "node scripts/sync-public-vendor-assets.mjs && cross-env NODE_ENV=development ALLOW_NEXT_DEV_FALLBACK=1 PORT=1989 PORT_FALLBACK=1990 CODEX_REUSE_EXISTING=1 UI_COMMAND=\"node server.cjs\" node start-all.cjs",
    "dev:lan": "node scripts/sync-public-vendor-assets.mjs && cross-env NODE_ENV=development ALLOW_NEXT_DEV_FALLBACK=1 DEV_LAN_ACCESS=1 UI_HOST=0.0.0.0 PORT=1989 PORT_FALLBACK=1990 SHOW_LAN_URLS=1 UI_COMMAND=\"node server.cjs\" node start-all.cjs",
    "dev:ui": "node scripts/sync-public-vendor-assets.mjs && cross-env NODE_ENV=development PORT=1989 PORT_FALLBACK=1990 node server.cjs",
    "build": "node scripts/sync-public-vendor-assets.mjs && next build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ci": "cross-env E2E_SKIP_BUILD=1 playwright test",
    "test:mutation": "stryker run",
    "test:watch": "vitest",
    "smoke": "node scripts/sync-public-vendor-assets.mjs && cross-env BASE_URL=http://127.0.0.1:1989 node scripts/smoke-control-center.mjs"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@highlightjs/cdn-assets": "11.11.1",
    "dompurify": "3.4.6",
    "fastify": "^5.8.5",
    "highlight.js": "11.11.1",
    "marked": "17.0.6",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ws": "^8.21.0"
  },
  "engines": {
    "node": ">=24 <27",
    "pnpm": ">=11 <12"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "eslint": "10.4.0",
    "happy-dom": "^20.9.0",
    "knip": "6.14.2",
    "playwright": "^1.60.0",
    "postcss": "8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typedoc": "0.28.19",
    "typedoc-plugin-markdown": "4.11.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.60.0",
    "vitest": "^4.1.7"
  }
}
