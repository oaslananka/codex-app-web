{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "pnpm",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts",
    "related": true
  },
  "mutate": [
    "src/lib/codex-runtime/sandbox-policy.ts",
    "src/lib/codex-runtime/terminal-output.ts",
    "src/lib/codex-runtime/utf8-base64.ts"
  ],
  "reporters": ["clear-text", "progress"],
  "thresholds": {
    "high": 85,
    "low": 80,
    "break": 80
  },
  "concurrency": 2,
  "tempDirName": ".stryker-tmp"
}
